# ── Secrets ──────────────────────────────────────────────────────────────────
.env

# ── Generated artifacts (rebuild with scripts/build_index.py) ────────────────
# Chunk JSONL files (text, but large build artifacts — not useful to version)
data/processed/chunks.jsonl
data/processed/chunks_sentence.jsonl
data/processed/chunks_semantic.jsonl
# FAISS binary indices (not human-readable, large)
data/processed/embeddings/
data/processed/embeddings_sentence/
data/processed/embeddings_semantic/

# ── Run outputs ───────────────────────────────────────────────────────────────
# Traces are verbose (full chunk text + answers); exclude to keep the repo lean
runs/traces.jsonl
runs/traces_sentence.jsonl
runs/traces_semantic.jsonl
# eval_results*.jsonl are small metric summaries — committed so the repo shows
# benchmark numbers without requiring the reader to re-run the pipeline
# (no exclusion here — all eval_results*.jsonl files are tracked)

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/
